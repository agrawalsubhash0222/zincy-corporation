{
  "expo": {
    "name": "",
    "slug": "zincy-corporation",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/images/zincycorp.png",

    "scheme": "zincycorporation",

    "userInterfaceStyle": "automatic",

    "splash": {
      "image": "./assets/images/zincycorp.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/zincycorp.png",
        "backgroundColor": "#ffffff"
      }
    },

    "ios": {
      "supportsTablet": true
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/zincy-logo.png",
          "imageWidth": 160,
          "resizeMode": "contain"
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    }
  }
}